{
  "manifest_version": 3,
  "name": "YouTube Playlist Progress Tracker",
  "version": "1.0.0",
  "description": "Track your progress through YouTube playlists with auto-detection and topic extraction.",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["utils.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
  "16": "icon16.png",
  "48": "icon48.png",
  "128": "icon128.png"
}
}
